{
  "name": "aias-tauri",
  "version": "5.1.5",
  "description": "AIAS texture processing toolbox rebuilt with Tauri.",
  "type": "commonjs",
  "scripts": {
    "start": "npm run tauri dev",
    "dev": "npm run tauri dev",
    "dev:renderer": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1",
    "tauri": "tauri",
    "check": "vite build",
    "build": "tauri build",
    "build:fast": "tauri build --debug",
    "postbuild": "node -e \"const{readdirSync,cpSync}=require('fs');const{join}=require('path');const dir='src-tauri/target/release/bundle/nsis';const version=require('./package.json').version;const file=`AIAS_${version}_x64-setup.exe`;if(readdirSync(dir).includes(file))cpSync(join(dir,file),join('dist',file))\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-updater": "^2.5.1",
    "lucide": "^1.24.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.3",
    "vite": "^6.0.3"
  }
}
