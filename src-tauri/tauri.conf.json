{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AIAS",
  "version": "5.1.0",
  "identifier": "studio.avroracl.aias",
  "build": {
    "beforeDevCommand": "npm run dev:renderer",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "vite build",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AIAS",
        "width": 1320,
        "height": 820,
        "minWidth": 1020,
        "minHeight": 680,
        "backgroundColor": "#121316"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk5NTZFNkQ1NzZFMTYwMwpSV1FERm01WGJXNlZDYVNGanhyeTNUY0UyOGVhVjZMT2xka0FJRlFnSXVaSGVUSXdMazRoZHFmQwo",
      "endpoints": [
        "https://github.com/AvroraCL/AIAS/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["../Aias.png"],
    "resources": {
      "target/release/WebView2Loader.dll": "."
    },
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  }
}
